# Supabase Configuration (Database & Authentication)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Gemini AI Configuration (Required for AI assistant integrations)
GEMINI_API_KEY="your-gemini-api-key"

# Resend Email Configuration (Primary service for transactional emails)
# Generate a key at: https://resend.com
RESEND_API_KEY="re_yourkey"

# Gmail SMTP Configuration (Fallback service for emails)
# GMAIL_APP_PASSWORD: 16-character code from: https://myaccount.google.com/apppasswords
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Notifications
SELLER_EMAIL="target-notifications@domain.com"

# Server Runtime Config
PORT=3000
NODE_ENV=development
